<group name="windows,sysmon,powershell,">

  <rule id="100100" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-(?:EncodedCommand|enc|e)\s</field>
    <description>Suspicious PowerShell encoded command detected (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_encoded,attack.execution,</group>
  </rule>

</group>

<group name="windows,sysmon,credential_access,">

<rule id="100101" level="12">
    <if_group>sysmon_eid10_detections</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe$</field>
    <description>Suspicious LSASS memory access — possible credential dumping (T1003.001)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_access,mimikatz,attack.credential_access,</group>
  </rule>
</group>


<group name="windows,sysmon,defense_evasion,">

  <rule id="100102" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Set-MpPreference.+Disable</field>
    <description>Windows Defender disabled via PowerShell (T1562.001)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>defense_evasion,attack.defense_evasion,</group>
  </rule>

</group>
